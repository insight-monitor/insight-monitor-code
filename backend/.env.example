# Insight Monitor — Environment Variables
# Copy this file to .env and fill in your values.
# cp .env.example .env

# --- LLM Configuration ---
# Provider: "openai" | "gemini"
LLM_PROVIDER=openai
# Model name (openai: gpt-4o-mini, gemini: gemini-2.0-flash)
LLM_MODEL=gpt-4o-mini
# Base URL for OpenAI-compatible API (leave empty for default https://api.openai.com/v1)
LLM_BASE_URL=
# API key for selected provider
API_KEY=your-openai-api-key-here

# --- Database ---
# Path to SQLite database file
DB_PATH=./data/insight_monitor.db

# --- API ---
# Version string returned by GET /health
API_VERSION=0.1.0
# Comma-separated list of allowed origins for the API
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Session Builder ---
# Minutes of inactivity before a session is considered closed
INACTIVITY_THRESHOLD_MINUTES=8
# Seconds between session builder poll cycles
SESSION_BUILDER_POLL_SECONDS=30

# --- Inference Pipeline ---
# Seconds between inference pipeline poll cycles
INFERENCE_POLL_SECONDS=60