# Insight Monitor — Environment Variables
# Copy this file to .env and fill in your values.
# cp .env.example .env

# --- Database ---
# Path to SQLite database file (default: backend/data/insight_monitor.db)
# INSIGHT_DB_PATH=./data/insight_monitor.db

# --- CORS ---
# Comma-separated list of allowed origins for the API (default: http://localhost:5173)
# INSIGHT_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- API ---
# Version string returned by GET /health (default: 0.1.0)
# INSIGHT_API_VERSION=0.1.0

# --- Gemini (Inference Pipeline) ---
# REQUIRED for Day 6+ — API key from Google AI Studio
GEMINI_API_KEY=your-gemini-api-key-here
# Gemini model name (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- Inference Pipeline ---
# Timeout in seconds for each LLM call (default: 30)
# INFERENCE_TIMEOUT_SEC=30
# Max retries on LLM failure (default: 3)
# INFERENCE_MAX_RETRIES=3

# --- Session Detection ---
# Minutes of inactivity before a session is considered closed (default: 8)
# SESSION_INACTIVITY_GAP_MIN=8

# --- Docker Compose (DB Infrastructure) ---
# Variables for db-enterprise docker-compose (defaults used if unset)
DB_ROOT_PASSWORD=rootpassword
DB_USER=insight_user
DB_PASSWORD=insight_password
# Variable for db-mvp docker-compose
SQLITE_WEB_PASSWORD=mvppassword
