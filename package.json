{
  "name": "insight-monitor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"API,FE\" -c \"blue,green\" \"npm run backend\" \"npm run frontend:dev\"",
    "backend": "cd backend && ../scripts/run-backend.sh",
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "capture": "cd capture && python agent.py",
    "seed": "cd backend && ../scripts/run-backend.sh seed",
    "simulate": "cd backend && ../scripts/run-backend.sh simulate",
    "generate:types": "python scripts/generate_types.py"
  },
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}
